[DEFAULT]
verbose = True
debug = True

[db]
connection_url = postgresql://exordos_core:exordos_core@127.0.0.1:5432/exordos_core
connection_pool_size = 2

[metrics]
enabled = False

[logging]
config = logging.yaml

[user_api]
bind_host = 0.0.0.0
bind_port = 11010

[iam]
global_salt = {{ global_salt }}
hs256_jwks_encryption_key = {{ hs256_jwks_encryption_key }}

[orch_api]
bind_host = 0.0.0.0
bind_port = 11011

[status_api]
bind_host = 0.0.0.0
bind_port = 11012

[boot_api]
bind_host = {{ boot_ip }}
bind_port = 11013
gc_boot_api = http://{{ boot_ip }}:11013
initrd = http://{{ boot_ip }}:8080/bios/initrd.img
kernel = http://{{ boot_ip }}:8080/bios/vmlinuz


[events]
enabled = False
