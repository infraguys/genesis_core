[DEFAULT]
verbose = True
debug = True


[db]
connection_url = postgresql://genesis_core:genesis_core@127.0.0.1:5432/genesis_core
connection_pool_size = 2


[universal_agent]
orch_secure_communication = False
orch_endpoint = http://{{ boot_ip }}:11013
status_endpoint = http://{{ boot_ip }}:11013
caps_drivers =
    RestCoreCapabilityDriver,
    PasswordCapabilityDriver,
    CoreDNSCertificateCapabilityDriver,
    LBAgentCapabilityDriver,
    GuestMachineCapabilityDriver


[universal_agent_scheduler]
capabilities =
    em_*,
    password,
    certificate,
    paas_lb_agent


[CoreDNSCertificateCapabilityDriver]
username = admin
password = admin
user_api_base_url = http://localhost:11010/v1


[RestCoreCapabilityDriver]
username = admin
password = admin
user_api_base_url = http://localhost:11010
em_core_iam_users = /v1/iam/users/
